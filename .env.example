# UUilly Environment Variables Template
# Copy this file to .env and fill in the values.

# ==========================================
# 1. DATABASE CONFIGURATION
# ==========================================
# Common settings for PostgreSQL and PgBouncer
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres # CHANGE IN PRODUCTION

# Database Names (Isolation)
UUILLY_DB_NAME=uuilly_db
N8N_DB_NAME=n8n_db
FLOWISE_DB_NAME=flowise_db

# Connection URL for Backend / Prisma
# Note: DATABASE_URL should point to the PgBouncer port (6432) or Postgres port (5432)
# Development: postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${UUILLY_DB_NAME}?schema=public
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${UUILLY_DB_NAME}?schema=public"

# Direct URL for Prisma migrations (bypassing PgBouncer)
# In production with PgBouncer, this SHOULD point to port 5432 directly.
DIRECT_DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${UUILLY_DB_NAME}?schema=public"

# Postgres Official Container Initialization
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=postgres

# ==========================================
# 2. REDIS CONFIGURATION
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# 3. EXTERNAL SERVICES (n8n / Flowise)
# ==========================================

# Flowise Configuration
FLOWISE_PORT=3001
FLOWISE_MODE=queue
FLOWISE_REDIS_URL=redis://redis:6379
# Security (Flowise v3.1.0+)
# Disable HTTP_SECURITY_CHECK to allow internal Docker communication (e.g. from Backend/Intelligence)
HTTP_SECURITY_CHECK=false
# Deny list (leave empty for internal development)
HTTP_DENY_LIST=

# Flowise Security (Critical for Production)
# Generate each with: openssl rand -hex 32
FLOWISE_SECRETKEY_OVERWRITE=your_flowise_secret_key_here
FLOWISE_JWT_AUTH_TOKEN_SECRET=your_flowise_jwt_secret_here
FLOWISE_EXPRESS_SESSION_SECRET=your_flowise_session_secret_here

# n8n Queue Mode Configuration
# EXECUTIONS_MODE=queue
# QUEUE_BULL_REDIS_HOST=redis
# QUEUE_BULL_REDIS_PORT=6379
# N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=false

# n8n Security (Critical for Production)
# Generate each with: openssl rand -hex 32
# N8N_ENCRYPTION_KEY=your_n8n_encryption_key_here
# N8N_USER_MANAGEMENT_JWT_SECRET=your_n8n_jwt_secret_here

# ==========================================
# 4. AUTHENTICATION & SECURITY
# ==========================================

# Google OAuth 2.0 (Obtain at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Security
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here

# Agent Credentials Encryption (AES-256)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AGENT_AUTH_ENCRYPTION_KEY=your_fernet_key_here

# ==========================================
# 5. SERVER URLs
# ==========================================
# Development: http://localhost:8080
# Production: https://your-domain.com
PUBLIC_SERVER_URL=http://localhost:8080
INTERNAL_SERVER_URL=http://uuilly-backend:8000

# ==========================================
# 6. USER BOOTSTRAP (Pre-load Admin/Users)
# ==========================================
# Pattern: USER_{n}_EMAIL, USER_{n}_PASSWORD, USER_{n}_ROLE, etc.

# User 1 (Admin)
USER_1_EMAIL=admin@example.com
USER_1_PASSWORD=devpassword
USER_1_ROLE=ADMIN
USER_1_FIRST_NAME=Admin
USER_1_LAST_NAME=Uuilly

# User 2 (User)
USER_2_EMAIL=user@example.com
USER_2_PASSWORD=devpassword
USER_2_ROLE=USER
USER_2_FIRST_NAME=Invitado
USER_2_LAST_NAME=Uuilly

# ==========================================
# 7. FRONTEND CONFIGURATION
# ==========================================
# Set to 'true' to show TanStack Query Devtools in the browser
VITE_SHOW_RQ_DEVTOOLS=false
